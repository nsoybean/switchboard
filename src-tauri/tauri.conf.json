{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Switchboard",
  "version": "0.1.1",
  "identifier": "dev.switchboard.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Switchboard",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/AppIcon16.png",
      "icons/AppIcon32.png",
      "icons/AppIcon64.png",
      "icons/AppIcon128.png",
      "icons/AppIcon256.png",
      "icons/AppIcon512.png",
      "icons/AppIcon1024.png",
      "icons/AppIcon.icns"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGMUQxRDk1RUUyOUZENTgKUldSWS9TbnVsUjBkLzhzYXN0bWFGUjEyc1ZnS1I5WlpwQlg3K2JtSXJCNGs0dGZ0ZlEyeUVML0oK",
      "endpoints": [
        "https://github.com/nsoybean/switchboard/releases/latest/download/latest.json"
      ]
    }
  }
}
